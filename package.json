{
  "name": "dmitriy_portfolio_nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "test -f new_resume.pdf && cp new_resume.pdf public/new_resume.pdf || true",
    "build": "next build",
    "postbuild": "next-sitemap",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "analyze": "ANALYZE=true next build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --max-warnings=0 --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "framer-motion": "^12.38.0",
    "next": "^14.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-google-recaptcha-v3": "^1.10.1",
    "react-responsive-carousel": "^3.2.23",
    "resend": "^6.12.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.2.4",
    "@types/node": "^20.19.0",
    "@types/react": "^18.3.12",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "autoprefixer": "^10.4.5",
    "eslint": "^8.14.0",
    "eslint-config-next": "^14.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.29.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.3",
    "next-sitemap": "^4.2.3",
    "postcss": "^8.4.12",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.6.3"
  }
}
