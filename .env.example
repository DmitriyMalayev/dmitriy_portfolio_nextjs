# Copy to `.env.local` — never commit real secrets.

# Google reCAPTCHA v3 — https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Resend — https://resend.com
RESEND_API_KEY=
CONTACT_TO_EMAIL=
RESEND_FROM_EMAIL=

# Used by `next-sitemap` (optional; defaults in next-sitemap.config.js)
SITE_URL=https://dmitriymalayev.com

# Set to `true` locally to inspect bundles: `npm run analyze`
# ANALYZE=false
